<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Baseline Drift Comparison</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 20px; }
    table { width: 100%; border-collapse: collapse; }
    th, td { border: 1px solid #ddd; padding: 8px; }
    th { background: #f4f4f4; }
  </style>
</head>
<body>
  <h1>Drift Comparison</h1>
  <p>Current run: {{ compare_run_id }} | Previous run: {{ compare_prev_run_id }}</p>
  <table>
    <thead>
      <tr>
        <th>Hostname</th><th>Comparable</th><th>Software</th><th>Services</th><th>Listeners</th><th>Destinations</th><th>Admins</th><th>Certs</th><th>IPs</th><th>Patch</th><th>Disk</th>
      </tr>
    </thead>
    <tbody>
      {% for item in compare_items %}
      <tr>
        <td>{{ item.hostname }}</td>
        <td>{{ item.comparable }}</td>
        <td>{{ item.changes.software_changed }}</td>
        <td>{{ item.changes.services_changed }}</td>
        <td>{{ item.changes.listeners_changed }}</td>
        <td>{{ item.changes.destinations_changed }}</td>
        <td>{{ item.changes.admins_changed }}</td>
        <td>{{ item.changes.certs_changed }}</td>
        <td>{{ item.changes.ips_changed }}</td>
        <td>{{ item.changes.patch_changed }}</td>
        <td>{{ item.changes.disk_changed }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</body>
</html>
