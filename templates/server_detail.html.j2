<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Server Detail - {{ server.server_identity.hostname }}</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 20px; }
    pre { background: #f6f8fa; padding: 12px; border: 1px solid #ddd; overflow-x: auto; }
  </style>
</head>
<body>
  <h1>{{ server.server_identity.hostname }}</h1>
  <p><a href="dashboard.html">Back to dashboard</a></p>

  <h2>Compliance Summary</h2>
  <pre>{{ server.compliance | tojson(indent=2) }}</pre>

  <h2>Process vs Port</h2>
  <pre>{{ server.process_port_map | tojson(indent=2) }}</pre>

  <h2>Process vs Destination</h2>
  <pre>{{ server.process_destination_map | tojson(indent=2) }}</pre>

  <h2>Full Normalized Baseline</h2>
  <pre>{{ server | tojson(indent=2) }}</pre>
</body>
</html>
